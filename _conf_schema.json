{
  "timezone": {
    "description": "课表与日报使用的时区",
    "type": "string",
    "default": "Asia/Shanghai",
    "hint": "例如 Asia/Shanghai"
  },
  "daily_report_time": {
    "description": "每日课时统计发送时间",
    "type": "string",
    "default": "22:30",
    "hint": "24 小时制 HH:MM，例如 22:30"
  },
  "daily_report_enabled_groups": {
    "description": "开启日报的群号列表",
    "type": "list",
    "default": [],
    "hint": "填写需要自动发送日报的 QQ 群号；群内命令开启的群也会发送"
  },
  "group_admins": {
    "description": "群课表管理员配置",
    "type": "dict",
    "default": {},
    "items": {},
    "hint": "格式：群号 -> 管理员 QQ 号列表，例如 {\"123456\": [\"10001\", \"10002\"]}"
  }
}
